# ─────────────────────────────────────────────
# clawd-bridge — configuration template
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Required ─────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot
# Find your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# Optional ─────────────────────────────────────

# Default Claude model alias (sonnet | opus | haiku)
DEFAULT_MODEL=sonnet

# Max runtime for Claude CLI calls in seconds
COMMAND_TIMEOUT_SECS=120

# Directory for SQLite database file
DATA_DIR=./data

# Directory for log files
LOG_DIR=./logs

# Logging level (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=INFO

# Trading system integration (optional) ────────
# Set to true to include trading system context in Claude's system prompt.
# Remove or set to false before publishing to open-source.
TRADING_SYSTEM_ENABLED=false
TRADING_SYSTEM_LOG_DIR=
TRADING_SYSTEM_CONFIG_PATH=
